---
import { getSiteSettings } from "../lib/content";
import { getVideoEmbed } from "../lib/media";

interface Props {
  title: string;
  videoUrl?: string;
  hostedVideoUrl?: string;
  videoFile?: string;
  tone?: "light" | "dark";
}

const { title, videoUrl, hostedVideoUrl, videoFile, tone = "light" } = Astro.props;
const embed = getVideoEmbed(videoUrl);
const settings = await getSiteSettings();
const directVideoUrl = embed?.type === "file" ? embed.src : undefined;
const isVimeo = embed?.type === "iframe" && embed.provider === "vimeo";
const isYouTube = embed?.type === "iframe" && embed.provider === "youtube";
---

{
  (videoFile || hostedVideoUrl || directVideoUrl || embed) && (
    <section class:list={["detail-block", tone === "dark" && "detail-block--dark"]}>
      {videoFile || hostedVideoUrl || directVideoUrl ? (
        <video class="video-frame" controls preload="metadata">
          <source src={hostedVideoUrl ?? directVideoUrl ?? videoFile} />
          {settings.videoUnsupportedLabel ?? "Tu navegador no soporta la reproduccion de video."}
        </video>
      ) : embed?.type === "iframe" ? (
        <div class:list={["video-frame", "video-frame--embed", isVimeo && "video-frame--vimeo", isYouTube && "video-frame--youtube"]}>
          <iframe
            class:list={["video-frame__embed", isVimeo && "video-frame__embed--vimeo", isYouTube && "video-frame__embed--youtube"]}
            src={embed.src}
            title={title}
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        </div>
      ) : embed ? (
        <p>
          <a href={embed.src} target="_blank" rel="noreferrer">
            {settings.videoExternalLabel ?? "Ver video externo"}
          </a>
        </p>
      ) : null}
    </section>
  )
}
