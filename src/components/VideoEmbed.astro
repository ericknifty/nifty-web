---
import { getSiteSettings } from "../lib/content";
import { getVideoEmbed } from "../lib/media";

interface Props {
  title: string;
  videoUrl?: string;
  videoFile?: string;
  tone?: "light" | "dark";
}

const { title, videoUrl, videoFile, tone = "light" } = Astro.props;
const embed = getVideoEmbed(videoUrl);
const settings = await getSiteSettings();
---

{
  (videoFile || embed) && (
    <section class:list={["detail-block", tone === "dark" && "detail-block--dark"]}>
      <div class="section-heading">
        <div>
          <p class="eyebrow">{settings.videoEyebrow ?? "Multimedia"}</p>
          <h2>{settings.videoTitle ?? "Video"}</h2>
        </div>
      </div>

      {videoFile ? (
        <video class="video-frame" controls preload="metadata">
          <source src={videoFile} />
          {settings.videoUnsupportedLabel ?? "Tu navegador no soporta la reproducción de video."}
        </video>
      ) : embed?.type === "iframe" ? (
        <div class="video-frame video-frame--embed">
          <iframe
            src={embed.src}
            title={title}
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        </div>
      ) : embed ? (
        <p>
          <a href={embed.src} target="_blank" rel="noreferrer">
            {settings.videoExternalLabel ?? "Ver video externo"}
          </a>
        </p>
      ) : null}
    </section>
  )
}
