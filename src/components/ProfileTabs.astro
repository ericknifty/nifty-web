---
import { render, type CollectionEntry } from "astro:content";
import DownloadList from "./DownloadList.astro";

interface Props {
  profiles: CollectionEntry<"cvProfiles">[];
  eyebrow?: string;
  title?: string;
  hideHeader?: boolean;
  startCollapsed?: boolean;
  buttonLabels?: Record<string, string>;
  hideControls?: boolean;
}

const {
  profiles,
  eyebrow = "CV",
  title = "Perfiles profesionales",
  hideHeader = false,
  startCollapsed = false,
  buttonLabels = {},
  hideControls = false
} = Astro.props;

const renderedProfiles = await Promise.all(
  profiles.map(async (profile) => {
    const { Content } = await render(profile);
    return {
      entry: profile,
      Content,
      profileId: profile.data.slug ?? profile.id
    };
  })
);
---

<section
  class="profile-tabs"
  data-profile-tabs
  data-start-collapsed={startCollapsed ? "true" : "false"}
>
  {
    (!hideHeader || !hideControls) && (
      <div class="profile-tabs__header">
        {
          !hideHeader && (
            <div>
              <p class="eyebrow">{eyebrow}</p>
              <h2>{title}</h2>
            </div>
          )
        }

        {
          !hideControls && (
            <div class="profile-tabs__controls" role="tablist" aria-label={title}>
              {
                renderedProfiles.map(({ entry, profileId }, index) => (
                  <button
                    type="button"
                    class:list={["profile-tabs__button", !startCollapsed && index === 0 && "is-active"]}
                    role="tab"
                    id={`tab-${profileId}`}
                    data-profile-tab={profileId}
                    aria-selected={!startCollapsed && index === 0 ? "true" : "false"}
                    aria-controls={`panel-${profileId}`}
                  >
                    {buttonLabels[profileId] ?? entry.data.tabLabel}
                  </button>
                ))
              }
            </div>
          )
        }
      </div>
    )
  }

  <div class="profile-tabs__panels">
    {
      renderedProfiles.map(({ entry, Content, profileId }, index) => (
        <article
          class:list={["profile-panel", !startCollapsed && index === 0 && "is-active"]}
          id={`panel-${profileId}`}
          data-profile-panel={profileId}
          role={hideControls ? "region" : "tabpanel"}
          aria-labelledby={hideControls ? undefined : `tab-${profileId}`}
          aria-label={hideControls ? entry.data.title : undefined}
          hidden={startCollapsed || index !== 0}
        >
          <div class="profile-panel__intro">
            {entry.data.summary && <p class="eyebrow">{entry.data.summary}</p>}
            <h3>{entry.data.title}</h3>
          </div>

          <div class="prose profile-panel__content">
            <Content />
          </div>

          {entry.data.attachments.length > 0 && <DownloadList files={entry.data.attachments} />}
        </article>
      ))
    }
  </div>
</section>

<script>
  const initProfileTabs = () => {
    document.querySelectorAll("[data-profile-tabs]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.ready === "true") return;

      const tabs = Array.from(root.querySelectorAll("[data-profile-tab]"));
      const panels = Array.from(root.querySelectorAll("[data-profile-panel]"));
      const startCollapsed = root.dataset.startCollapsed === "true";

      const activate = (target) => {
        tabs.forEach((tab) => {
          if (!(tab instanceof HTMLButtonElement)) return;
          const isActive = tab.dataset.profileTab === target;
          tab.classList.toggle("is-active", isActive);
          tab.setAttribute("aria-selected", String(isActive));
        });

        panels.forEach((panel) => {
          if (!(panel instanceof HTMLElement)) return;
          const isActive = panel.dataset.profilePanel === target;
          panel.hidden = !isActive;
          panel.classList.toggle("is-active", isActive);
        });
      };

      root.addEventListener("profile-tabs:activate", (event) => {
        const target = event instanceof CustomEvent ? event.detail?.target : undefined;
        if (typeof target === "string") {
          activate(target);
        }
      });

      tabs.forEach((tab) => {
        if (!(tab instanceof HTMLButtonElement)) return;
        tab.addEventListener("click", () => activate(tab.dataset.profileTab));
      });

      const firstTab = tabs[0];
      if (!startCollapsed && firstTab instanceof HTMLButtonElement && firstTab.dataset.profileTab) {
        activate(firstTab.dataset.profileTab);
      }

      root.dataset.ready = "true";
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProfileTabs, { once: true });
  } else {
    initProfileTabs();
  }

  document.addEventListener("astro:page-load", initProfileTabs);
</script>
