---
import { fileLabel, getSiteSettings } from "../lib/content";

interface Props {
  files: string[];
  tone?: "light" | "dark";
}

const { files, tone = "light" } = Astro.props;
const settings = await getSiteSettings();
---

{
  files.length > 0 && (
    <section class:list={["detail-block", tone === "dark" && "detail-block--dark"]}>
      <div class="section-heading">
        <div>
          <p class="eyebrow">{settings.downloadsEyebrow ?? "Recursos"}</p>
          <h2>{settings.downloadsTitle ?? "Descargas"}</h2>
        </div>
      </div>

      <ul class="download-list">
        {files.map((file) => <li><a href={file}>{fileLabel(file)}</a></li>)}
      </ul>
    </section>
  )
}
