---
import BrandMark from "./BrandMark.astro";

interface Props {
  currentPath: string;
  settings: {
    navHomeLabel?: string;
    navAboutLabel?: string;
    navCvLabel?: string;
    navPortfolioLabel?: string;
    navBlogLabel?: string;
    navToolsLabel?: string;
  };
}

const { currentPath, settings } = Astro.props;

const navItems = [
  { href: "/", label: settings.navHomeLabel ?? "Inicio" },
  { href: "/sobre-mi", label: settings.navAboutLabel ?? "Sobre mí" },
  { href: "/cv", label: settings.navCvLabel ?? "CV" },
  { href: "/portafolio", label: settings.navPortfolioLabel ?? "Portafolio" },
  { href: "/blog", label: settings.navBlogLabel ?? "Blog" },
  { href: "/utilidades", label: settings.navToolsLabel ?? "Utilidades" }
];

const isActive = (href: string) => (href === "/" ? currentPath === href : currentPath.startsWith(href));
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href="/">
      <BrandMark variant="isologo" width={200} height={83} />
    </a>

    <nav class="site-nav" aria-label="Principal">
      {
        navItems.map((item) => (
          <a class:list={["site-nav__link", isActive(item.href) && "is-active"]} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
