---
import { render } from "astro:content";
import BrandMark from "../components/BrandMark.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileTabs from "../components/ProfileTabs.astro";
import { getPageContent, getSiteSettings, getVisibleCvProfiles } from "../lib/content";

const settings = await getSiteSettings();
const page = await getPageContent("sobre-mi");
const profiles = await getVisibleCvProfiles();
const hasHeroImage = Boolean(page?.data.heroImage);

if (!page) {
  throw new Error("Falta src/content/pages/sobre-mi.md");
}

const { Content } = await render(page);
---

<BaseLayout title={`${settings.siteName} | Bio`} description={page.data.intro ?? settings.siteDescription}>
  <section class="page-hero">
    <div class="shell about-hero">
      <div class="page-hero__copy about-hero__copy">
        <p class="eyebrow">{page.data.eyebrow ?? "Perfil"}</p>
        <h1>{page.data.title}</h1>
        {page.data.intro && <p class="page-hero__intro">{page.data.intro}</p>}
        {page.data.lead && <p class="page-hero__lead">{page.data.lead}</p>}
      </div>

      <aside class:list={["about-hero__media", !hasHeroImage && "about-hero__media--placeholder"]}>
        <div class:list={["about-hero__frame", !hasHeroImage && "about-hero__frame--placeholder"]}>
          {
            hasHeroImage ? (
              <img src={page.data.heroImage} alt={page.data.heroImageAlt || ""} />
            ) : (
              <div class="about-hero__placeholder" data-eye-follow>
                <div class="about-hero__placeholder-mark" data-eye-follow-mark>
                  <BrandMark variant="isotipo" width={425} height={432} label="Isotipo Taller Nifty" />
                </div>
              </div>
            )
          }
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell prose prose--wide">
      <Content />

      {
        (page.data.contactPrimaryUrl || page.data.contactSecondaryUrl) && (
          <div class="about-contact-actions">
            {
              page.data.contactPrimaryUrl && (
                <a class="button" href={page.data.contactPrimaryUrl}>
                  {page.data.contactPrimaryLabel ?? page.data.contactPrimaryUrl.replace("mailto:", "")}
                </a>
              )
            }
            {
              page.data.contactSecondaryUrl && (
                <a class="button button--secondary" href={page.data.contactSecondaryUrl}>
                  {page.data.contactSecondaryLabel ?? page.data.contactSecondaryUrl.replace("mailto:", "")}
                </a>
              )
            }
          </div>
        )
      }
    </div>
  </section>

  <section class="section section--tight" id="experiencia">
    <div class="shell">
      <ProfileTabs profiles={profiles} hideHeader={true} hideControls={true} startCollapsed={true} />
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (prefersReducedMotion.matches) {
      return;
    }

    const placeholder = document.querySelector("[data-eye-follow]");
    const svg = placeholder?.querySelector(".brand-mark__svg");
    const pupilGroup = svg?.querySelector("#ojo_pupila");

    if (!(svg instanceof SVGSVGElement) || !(pupilGroup instanceof SVGGElement)) {
      return;
    }

    let pointerActive = false;
    let touchPointerId = null;
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let frameId = 0;
    const maxTravel = 2.8;

    const render = () => {
      currentX += (targetX - currentX) * 0.16;
      currentY += (targetY - currentY) * 0.16;

      if (Math.abs(targetX - currentX) < 0.01 && Math.abs(targetY - currentY) < 0.01) {
        currentX = targetX;
        currentY = targetY;
      }

      pupilGroup.setAttribute("transform", `translate(${currentX.toFixed(2)} ${currentY.toFixed(2)})`);

      if (pointerActive || Math.abs(targetX - currentX) > 0.01 || Math.abs(targetY - currentY) > 0.01) {
        frameId = window.requestAnimationFrame(render);
      } else {
        frameId = 0;
      }
    };

    const startLoop = () => {
      if (!frameId) {
        frameId = window.requestAnimationFrame(render);
      }
    };

    const updateTarget = (event) => {
      const rect = svg.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      const deltaX = (event.clientX - centerX) / (rect.width / 2);
      const deltaY = (event.clientY - centerY) / (rect.height / 2);
      const distance = Math.hypot(deltaX, deltaY) || 1;
      const clamped = Math.min(1, distance);

      pointerActive = true;
      targetX = (deltaX / distance) * maxTravel * clamped;
      targetY = (deltaY / distance) * maxTravel * clamped;
      startLoop();
    };

    const reset = () => {
      pointerActive = false;
      touchPointerId = null;
      targetX = 0;
      targetY = 0;
      startLoop();
    };

    const onPointerMove = (event) => {
      if (event.pointerType === "mouse") {
        updateTarget(event);
        return;
      }

      if (touchPointerId === event.pointerId) {
        updateTarget(event);
      }
    };

    const onPointerDown = (event) => {
      if (event.pointerType !== "mouse") {
        touchPointerId = event.pointerId;
      }

      updateTarget(event);
    };

    const onPointerUp = (event) => {
      if (event.pointerType === "mouse") {
        return;
      }

      if (touchPointerId === event.pointerId) {
        reset();
      }
    };

    window.addEventListener("pointermove", onPointerMove, { passive: true });
    window.addEventListener("pointerdown", onPointerDown, { passive: true });
    window.addEventListener("pointerup", onPointerUp, { passive: true });
    window.addEventListener("pointercancel", reset);
    window.addEventListener("pointerleave", reset);
    window.addEventListener("blur", reset);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        reset();
      }
    });
  })();

  (() => {
    const profileTabs = document.querySelector("[data-profile-tabs]");
    const experienceSection = document.querySelector("#experiencia");

    if (!(profileTabs instanceof HTMLElement)) {
      return;
    }

    const profileHashMap = {
      "#perfil-motion": "motion",
      "#perfil-print": "print"
    };

    const activateFromHash = (hash, smooth = false) => {
      const target = profileHashMap[hash];

      if (!target) {
        return;
      }

      profileTabs.dispatchEvent(
        new CustomEvent("profile-tabs:activate", {
          detail: { target }
        })
      );

      if (experienceSection instanceof HTMLElement) {
        experienceSection.scrollIntoView({
          behavior: smooth ? "smooth" : "auto",
          block: "start"
        });
      }
    };

    document.querySelectorAll('a[href="#perfil-motion"], a[href="#perfil-print"]').forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;

      link.addEventListener("click", (event) => {
        event.preventDefault();
        const hash = link.getAttribute("href") ?? "";
        history.replaceState(null, "", hash);
        activateFromHash(hash, true);
      });
    });

    window.addEventListener("hashchange", () => activateFromHash(window.location.hash));
    activateFromHash(window.location.hash);
  })();
</script>
