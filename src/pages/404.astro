---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 | Taller Nifty" description="La página que buscas no existe o cambió de dirección.">
  <section class="section">
    <div class="shell empty-state">
      <p class="eyebrow">404</p>
      <h1>Página no encontrada</h1>
      <p>La ruta que abriste no existe todavía o fue movida a otra sección.</p>
      <a class="button" href="/">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
