---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteSettings } from "../lib/content";

const settings = await getSiteSettings();
---

<BaseLayout title={`${settings.siteName} | Bio`} description={settings.siteDescription}>
  <section class="section">
    <div class="shell empty-state">
      <p class="eyebrow">Bio</p>
      <h1>La experiencia completa ahora vive dentro de Bio.</h1>
      <p>Desde ahí puedes abrir el perfil Motion Graphics o Producción Gráfica según lo que quieras revisar.</p>
      <a class="button" href="/sobre-mi#experiencia">Ir a Bio</a>
    </div>
  </section>

  <script is:inline>
    window.location.replace("/sobre-mi#experiencia");
  </script>
</BaseLayout>
