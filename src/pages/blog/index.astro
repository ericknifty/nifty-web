---
import ContentCard from "../../components/ContentCard.astro";
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getCategoryLabel,
  getPageContent,
  getSiteSettings,
  getVisiblePosts,
  routeSlug
} from "../../lib/content";

const settings = await getSiteSettings();
const page = await getPageContent("blog");
const posts = await getVisiblePosts();

if (!page) {
  throw new Error("Falta src/content/pages/blog.md");
}
---

<BaseLayout title={`${settings.siteName} | Blog`} description={page.data.intro ?? settings.siteDescription}>
  <PageHero
    eyebrow={page.data.eyebrow ?? "Blog"}
    title={page.data.title}
    intro={page.data.intro}
    lead={page.data.lead}
  />

  <section class="section">
    {
      posts.length > 0 ? (
        <div class="shell card-grid">
          {
            posts.map((post) => (
              <ContentCard
                href={`/blog/${routeSlug(post)}`}
                title={post.data.title}
                eyebrow={getCategoryLabel(post.data.category)}
                summary={post.data.excerpt}
                image={post.data.cover}
                meta={formatDate(post.data.date)}
                tags={post.data.tags}
              />
            ))
          }
        </div>
      ) : (
        <div class="shell empty-state">
          <p class="eyebrow">{page.data.eyebrow ?? "Blog"}</p>
          <h2>{page.data.emptyTitle ?? "Aun no hay posts publicados"}</h2>
          <p>{page.data.emptyBody ?? "Cuando publiques una entrada sin marcarla como borrador, aparecera aqui automaticamente."}</p>
        </div>
      )
    }
  </section>
</BaseLayout>
