---
import ContentCard from "../../components/ContentCard.astro";
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getCategoryLabel, getSiteSettings, getVisiblePosts, routeSlug } from "../../lib/content";

const settings = await getSiteSettings();
const posts = await getVisiblePosts();
---

<BaseLayout title={`${settings.siteName} | Blog`} description="Entradas de proceso, reflexión y documentación del trabajo.">
  <PageHero
    eyebrow="Blog"
    title="Posts y bitácora"
    intro="Acá vive el contenido editorial del sitio: procesos, reflexiones, pruebas y aprendizajes."
    lead="Aquí conviven artículos de oficio, observaciones sobre proyectos reales y notas que ayudan a entender mejor cada área de trabajo."
  />

  <section class="section">
    {
      posts.length > 0 ? (
        <div class="shell card-grid">
          {
            posts.map((post) => (
              <ContentCard
                href={`/blog/${routeSlug(post)}`}
                title={post.data.title}
                eyebrow={getCategoryLabel(post.data.category)}
                summary={post.data.excerpt}
                image={post.data.cover}
                meta={formatDate(post.data.date)}
                tags={post.data.tags}
              />
            ))
          }
        </div>
      ) : (
        <div class="shell empty-state">
          <p class="eyebrow">Blog</p>
          <h2>Aún no hay posts publicados</h2>
          <p>Cuando publiques una entrada sin marcarla como borrador, aparecerá aquí automáticamente.</p>
        </div>
      )
    }
  </section>
</BaseLayout>
