---
import { render } from "astro:content";
import ContentCard from "../components/ContentCard.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatDate,
  getAreaLabel,
  getCategoryLabel,
  getPageContent,
  getSiteSettings,
  getStatusLabel,
  getVisiblePosts,
  getVisibleProjects,
  getVisibleTools,
  routeSlug
} from "../lib/content";

const settings = await getSiteSettings();
const home = await getPageContent("inicio");

if (!home) {
  throw new Error("Falta src/content/pages/inicio.md");
}

const { Content } = await render(home);
const featuredProjects = (await getVisibleProjects())
  .filter((entry) => entry.data.featured)
  .map((project) => ({
    href: `/portafolio/${routeSlug(project)}`,
    title: project.data.title,
    eyebrow: "Portafolio",
    summary: project.data.summary,
    image: project.data.cover,
    meta: formatDate(project.data.date),
    tags: project.data.tags
  }));
const featuredPosts = (await getVisiblePosts())
  .filter((entry) => entry.data.featured)
  .map((post) => ({
    href: `/blog/${routeSlug(post)}`,
    title: post.data.title,
    eyebrow: "Blog",
    summary: post.data.excerpt,
    image: post.data.cover,
    meta: formatDate(post.data.date),
    tags: post.data.tags
  }));
const featuredTools = (await getVisibleTools())
  .filter((entry) => entry.data.featured)
  .map((tool) => ({
    href: `/utilidades/${routeSlug(tool)}`,
    title: tool.data.title,
    eyebrow: "Utilidad",
    summary: tool.data.summary,
    image: tool.data.cover,
    meta: getStatusLabel(tool.data.status),
    tags: []
  }));
const featuredItems = [...featuredProjects, ...featuredPosts, ...featuredTools].slice(0, 6);
const posts = await getVisiblePosts(3);
const tools = (await getVisibleTools()).slice(0, 2);

const portfolioAreas = [
  { key: "motion", label: getAreaLabel("motion"), copy: "Piezas audiovisuales, motion graphics, reels y presentaciones." },
  { key: "print", label: getAreaLabel("print"), copy: "Producción gráfica, imprenta, piezas editoriales y sistemas impresos." },
  { key: "web", label: getAreaLabel("web"), copy: "Sitios, landings, demos y soluciones digitales con foco visual." }
];

const heroActions: { href: string; label: string; variant?: "primary" | "secondary" }[] = [
  { href: settings.primaryCtaUrl, label: settings.primaryCtaLabel }
];

if (settings.secondaryCtaLabel && settings.secondaryCtaUrl) {
  heroActions.push({
    href: settings.secondaryCtaUrl,
    label: settings.secondaryCtaLabel,
    variant: "secondary"
  });
}
---

<BaseLayout title={`${settings.siteName} | Inicio`} description={settings.siteDescription}>
  <PageHero
    eyebrow="Portafolio + Blog + Demos"
    title={settings.siteTagline}
    intro={home.data.intro}
    lead={home.data.lead}
    actions={heroActions}
    panelEyebrow="Enfoque"
    panelTitle="Dos perfiles complementarios para proyectos B2B y de producción."
    panelBody="El sitio reúne experiencia audiovisual, producción gráfica y soluciones web ligeras para mostrar trabajo real, documentación de procesos y demos aplicadas."
    panelItems={[
      "Motion graphics, infografía animada y E-learning corporativo.",
      "Producción gráfica, pre-prensa y operación técnica industrial.",
      "Desarrollo web visual para demos, portafolio y herramientas digitales."
    ]}
  />

  <section class="section">
    <div class="shell two-column">
      <div class="prose">
        <Content />
      </div>

      <aside class="stack-card">
        <p class="eyebrow">Servicios</p>
        <h2>Qué puedes encontrar y solicitar aquí</h2>
        <ul class="stack-list">
          <li><strong>Motion B2B:</strong> piezas animadas para ventas, inducción, tutoriales y contenidos técnicos.</li>
          <li><strong>Producción gráfica:</strong> pre-prensa, datos variables, impresión y ejecución técnica.</li>
          <li><strong>Desarrollo web:</strong> landings, demos y soluciones ligeras con foco en claridad visual.</li>
          <li><strong>Bitácora profesional:</strong> artículos y procesos para documentar cómo se construyen las soluciones.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Selecciones del editor</p>
        <h2>Destacados</h2>
      </div>
    </div>

    <div class="shell card-grid">
      {
        featuredItems.map((item) => (
          <ContentCard
            href={item.href}
            title={item.title}
            eyebrow={item.eyebrow}
            summary={item.summary}
            image={item.image}
            meta={item.meta}
            tags={item.tags}
          />
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Portafolio</p>
        <h2>Áreas principales</h2>
      </div>
      <a href="/portafolio">Ver todo el portafolio</a>
    </div>

    <div class="shell area-grid">
      {portfolioAreas.map((area) => (
        <article class="area-card">
          <p class="eyebrow">{area.key}</p>
          <h3>{area.label}</h3>
          <p>{area.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Bitácora</p>
        <h2>Últimos posts</h2>
      </div>
      <a href="/blog">Ir al blog</a>
    </div>

    <div class="shell card-grid">
      {
        posts.map((post) => (
          <ContentCard
            href={`/blog/${routeSlug(post)}`}
            title={post.data.title}
            eyebrow={getCategoryLabel(post.data.category)}
            summary={post.data.excerpt}
            image={post.data.cover}
            meta={formatDate(post.data.date)}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Laboratorio</p>
        <h2>Utilidades y demos</h2>
      </div>
      <a href="/utilidades">Ver utilidades</a>
    </div>

    <div class="shell card-grid card-grid--compact">
      {
        tools.map((tool) => (
          <ContentCard
            href={`/utilidades/${routeSlug(tool)}`}
            title={tool.data.title}
            eyebrow={getStatusLabel(tool.data.status)}
            summary={tool.data.summary}
            image={tool.data.cover}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
