---
import { render } from "astro:content";
import ContentCard from "../components/ContentCard.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatDate,
  getAreaLabel,
  getCategoryLabel,
  getPageContent,
  getSiteSettings,
  getStatusLabel,
  getVisiblePosts,
  getVisibleProjects,
  getVisibleTools,
  routeSlug
} from "../lib/content";

const settings = await getSiteSettings();
const home = await getPageContent("inicio");

if (!home) {
  throw new Error("Falta src/content/pages/inicio.md");
}

const { Content } = await render(home);
const featuredProjects = (await getVisibleProjects())
  .filter((entry) => entry.data.featured)
  .map((project) => ({
    href: `/portafolio/${routeSlug(project)}`,
    title: project.data.title,
    eyebrow: "Portafolio",
    summary: project.data.summary,
    image: project.data.cover,
    meta: formatDate(project.data.date),
    tags: project.data.tags
  }));
const featuredPosts = (await getVisiblePosts())
  .filter((entry) => entry.data.featured)
  .map((post) => ({
    href: `/blog/${routeSlug(post)}`,
    title: post.data.title,
    eyebrow: "Blog",
    summary: post.data.excerpt,
    image: post.data.cover,
    meta: formatDate(post.data.date),
    tags: post.data.tags
  }));
const featuredTools = (await getVisibleTools())
  .filter((entry) => entry.data.featured)
  .map((tool) => ({
    href: `/utilidades/${routeSlug(tool)}`,
    title: tool.data.title,
    eyebrow: "Utilidad",
    summary: tool.data.summary,
    image: tool.data.cover,
    meta: getStatusLabel(tool.data.status),
    tags: []
  }));
const featuredItems = [...featuredProjects, ...featuredPosts, ...featuredTools].slice(0, 6);
const posts = await getVisiblePosts(3);
const tools = (await getVisibleTools()).slice(0, 2);
const portfolioAreas = [
  {
    key: "motion",
    label: getAreaLabel("motion"),
    copy: home.data.areaMotionCopy ?? "Piezas audiovisuales, motion graphics, reels y presentaciones."
  },
  {
    key: "print",
    label: getAreaLabel("print"),
    copy: home.data.areaPrintCopy ?? "Produccion grafica, imprenta, piezas editoriales y sistemas impresos."
  },
  {
    key: "web",
    label: getAreaLabel("web"),
    copy: home.data.areaWebCopy ?? "Sitios, landings, demos y soluciones digitales con foco visual."
  }
];
const serviceItems =
  home.data.serviceItems.length > 0
    ? home.data.serviceItems
    : [
        "Motion B2B: piezas animadas para ventas, induccion, tutoriales y contenidos tecnicos.",
        "Produccion grafica: pre-prensa, datos variables, impresion y ejecucion tecnica.",
        "Desarrollo web: landings, demos y soluciones ligeras con foco en claridad visual.",
        "Bitacora profesional: articulos y procesos para documentar como se construyen las soluciones."
      ];

const heroActions: { href: string; label: string; variant?: "primary" | "secondary" }[] = [
  { href: settings.primaryCtaUrl, label: settings.primaryCtaLabel }
];

if (settings.secondaryCtaLabel && settings.secondaryCtaUrl) {
  heroActions.push({
    href: settings.secondaryCtaUrl,
    label: settings.secondaryCtaLabel,
    variant: "secondary"
  });
}
---

<BaseLayout title={`${settings.siteName} | Inicio`} description={settings.siteDescription}>
  <PageHero
    eyebrow={home.data.eyebrow ?? "Portafolio + Blog + Demos"}
    title={settings.siteTagline}
    intro={home.data.intro}
    lead={home.data.lead}
    actions={heroActions}
    panelEyebrow={home.data.panelEyebrow}
    panelTitle={home.data.panelTitle}
    panelBody={home.data.panelBody}
    panelItems={home.data.panelItems}
  />

  <section class="section">
    <div class="shell two-column">
      <div class="prose">
        <Content />
      </div>

      <aside class="stack-card">
        <p class="eyebrow">Servicios</p>
        <h2>{home.data.serviceTitle ?? "Que puedes encontrar y solicitar aqui"}</h2>
        <ul class="stack-list">
          {serviceItems.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Selecciones del editor</p>
        <h2>Destacados</h2>
      </div>
    </div>

    <div class="shell card-grid">
      {
        featuredItems.map((item) => (
          <ContentCard
            href={item.href}
            title={item.title}
            eyebrow={item.eyebrow}
            summary={item.summary}
            image={item.image}
            meta={item.meta}
            tags={item.tags}
          />
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Portafolio</p>
        <h2>Areas principales</h2>
      </div>
      <a href="/portafolio">Ver todo el portafolio</a>
    </div>

    <div class="shell area-grid">
      {portfolioAreas.map((area) => (
        <article class="area-card">
          <p class="eyebrow">{area.key}</p>
          <h3>{area.label}</h3>
          <p>{area.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Bitacora</p>
        <h2>Ultimos posts</h2>
      </div>
      <a href="/blog">Ir al blog</a>
    </div>

    <div class="shell card-grid">
      {
        posts.map((post) => (
          <ContentCard
            href={`/blog/${routeSlug(post)}`}
            title={post.data.title}
            eyebrow={getCategoryLabel(post.data.category)}
            summary={post.data.excerpt}
            image={post.data.cover}
            meta={formatDate(post.data.date)}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Laboratorio</p>
        <h2>Utilidades y demos</h2>
      </div>
      <a href="/utilidades">Ver utilidades</a>
    </div>

    <div class="shell card-grid card-grid--compact">
      {
        tools.map((tool) => (
          <ContentCard
            href={`/utilidades/${routeSlug(tool)}`}
            title={tool.data.title}
            eyebrow={getStatusLabel(tool.data.status)}
            summary={tool.data.summary}
            image={tool.data.cover}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
