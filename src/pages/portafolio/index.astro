---
import ContentCard from "../../components/ContentCard.astro";
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAreaLabel, getSiteSettings, getVisibleProjects, routeSlug } from "../../lib/content";

const settings = await getSiteSettings();
const projects = await getVisibleProjects();
const areas = ["motion", "print", "web"] as const;
---

<BaseLayout title={`${settings.siteName} | Portafolio`} description="Portafolio organizado por motion graphics, imprenta y desarrollo web.">
  <PageHero
    eyebrow="Portafolio"
    title="Proyectos por área"
    intro="Esta sección muestra trabajos filtrados por las tres disciplinas principales del sitio."
    lead="La organización por área hace más fácil presentar experiencia específica sin perder una visión global del perfil."
  />

  {
    areas.map((area) => {
      const items = projects.filter((project) => project.data.area === area);

      return (
        <section class="section">
          <div class="shell section-heading">
            <div>
              <p class="eyebrow">{area}</p>
              <h2>{getAreaLabel(area)}</h2>
            </div>
            <p>{items.length} proyecto(s)</p>
          </div>

          <div class="shell card-grid">
            {items.map((project) => (
              <ContentCard
                href={`/portafolio/${routeSlug(project)}`}
                title={project.data.title}
                eyebrow={getAreaLabel(project.data.area)}
                summary={project.data.summary}
                image={project.data.cover}
                meta={formatDate(project.data.date)}
                tags={project.data.tags}
              />
            ))}
          </div>
        </section>
      );
    })
  }
</BaseLayout>
