---
import ContentCard from "../../components/ContentCard.astro";
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getAreaLabel,
  getPageContent,
  getSiteSettings,
  getVisibleProjects,
  routeSlug
} from "../../lib/content";

const settings = await getSiteSettings();
const page = await getPageContent("portafolio");
const projects = await getVisibleProjects();
const areas = ["motion", "print", "web"] as const;

if (!page) {
  throw new Error("Falta src/content/pages/portafolio.md");
}
---

<BaseLayout
  title={`${settings.siteName} | Portafolio`}
  description={page.data.intro ?? settings.siteDescription}
>
  <PageHero
    eyebrow={page.data.eyebrow ?? "Portafolio"}
    title={page.data.title}
    intro={page.data.intro}
    lead={page.data.lead}
  />

  {
    areas.map((area) => {
      const items = projects.filter((project) => project.data.area === area);

      return (
        <section class="section">
          <div class="shell section-heading">
            <div>
              <p class="eyebrow">{area}</p>
              <h2>{getAreaLabel(area)}</h2>
            </div>
            <p>{items.length} proyecto(s)</p>
          </div>

          <div class="shell card-grid">
            {items.map((project) => (
              <ContentCard
                href={`/portafolio/${routeSlug(project)}`}
                title={project.data.title}
                eyebrow={getAreaLabel(project.data.area)}
                summary={project.data.summary}
                image={project.data.cover}
                meta={formatDate(project.data.date)}
                tags={project.data.tags}
              />
            ))}
          </div>
        </section>
      );
    })
  }
</BaseLayout>
