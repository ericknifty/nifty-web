---
import { render } from "astro:content";
import DownloadList from "../../components/DownloadList.astro";
import LottiePlayer from "../../components/LottiePlayer.astro";
import PageHero from "../../components/PageHero.astro";
import VideoEmbed from "../../components/VideoEmbed.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAreaLabel, getSiteSettings, getVisibleProjects, routeSlug } from "../../lib/content";

export async function getStaticPaths() {
  const projects = await getVisibleProjects();
  return projects.map((entry) => ({
    params: { slug: routeSlug(entry) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const settings = await getSiteSettings();
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | ${settings.siteName}`} description={entry.data.summary}>
  <section class="page-hero">
    <div class="shell">
      <div class="page-hero__copy">
        {entry.data.cover && <img class="cover-image cover-image--hero" src={entry.data.cover} alt="" />}
        <p class="eyebrow">{getAreaLabel(entry.data.area)}</p>
        <h1>{entry.data.title}</h1>
        {entry.data.summary && <p class="page-hero__intro page-hero__intro--wide">{entry.data.summary}</p>}
        <p class="page-hero__lead page-hero__lead--wide">
          {entry.data.detailLead ?? `${settings.projectDatePrefix ?? "Actualizado el"} ${formatDate(entry.data.date)}`}
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell detail-stack">
      <article class="prose prose--wide detail-article">
        <VideoEmbed title={entry.data.title} videoUrl={entry.data.videoUrl} videoFile={entry.data.videoFile} />
        <LottiePlayer src={entry.data.lottieFile} title={entry.data.title} />
        <Content />

        {
          entry.data.gallery.length > 0 && (
            <section class="detail-block">
              <div class="section-heading">
                <div>
                  <p class="eyebrow">{settings.projectGalleryEyebrow ?? "Galeria"}</p>
                  <h2>{settings.projectGalleryTitle ?? "Imagenes del proyecto"}</h2>
                </div>
              </div>
              <div class="gallery-grid">
                {entry.data.gallery.map((image) => <img src={image} alt="" loading="lazy" />)}
              </div>
            </section>
          )
        }
        <DownloadList files={entry.data.downloads} />
      </article>
    </div>
  </section>
</BaseLayout>
