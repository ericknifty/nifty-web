---
import ContentCard from "../../components/ContentCard.astro";
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getPageContent,
  getSiteSettings,
  getStatusLabel,
  getVisibleTools,
  routeSlug
} from "../../lib/content";

const settings = await getSiteSettings();
const page = await getPageContent("utilidades");
const tools = await getVisibleTools();

if (!page) {
  throw new Error("Falta src/content/pages/utilidades.md");
}
---

<BaseLayout title={`${settings.siteName} | Utilidades`} description={page.data.intro ?? settings.siteDescription}>
  <PageHero
    eyebrow={page.data.eyebrow ?? "Utilidades"}
    title={page.data.title}
    intro={page.data.intro}
    lead={page.data.lead}
  />

  <section class="section">
    <div class="shell card-grid">
      {
        tools.map((tool) => (
          <ContentCard
            href={`/utilidades/${routeSlug(tool)}`}
            title={tool.data.title}
            eyebrow={getStatusLabel(tool.data.status)}
            summary={tool.data.summary}
            image={tool.data.cover}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
