---
const target = "/utilidades/imposicion-app/index.html";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <meta name="robots" content="noindex" />
    <title>Abriendo utilidad...</title>
    <link rel="canonical" href={target} />
  </head>
  <body>
    <script>
      window.location.replace("/utilidades/imposicion-app/index.html");
    </script>
    <p>
      Abriendo utilidad. Si no redirige automáticamente,
      <a href={target}>haz clic aquí</a>.
    </p>
  </body>
</html>
